---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 4em;
			}

			/* Hero */
			.hero {
				display: flex;
				align-items: center;
				gap: 2.5rem;
				margin-bottom: 2.5rem;
			}
			.hero-photo {
				width: 130px;
				height: 130px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
				box-shadow: var(--box-shadow);
			}
			.hero-text h1 {
				font-size: 2.2em;
				margin-bottom: 0.15em;
			}
			.hero-text .tagline {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin-bottom: 0.75em;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				font-weight: 600;
			}
			.hero-text p {
				font-size: 0.95em;
				line-height: 1.7;
				margin: 0 0 0.6em;
				color: rgb(var(--gray-dark));
			}
			.hero-text p:last-child {
				margin-bottom: 0;
			}

			/* Section label */
			.section-label {
				font-size: 0.75em;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-weight: 700;
				color: rgb(var(--gray));
				margin: 2.5rem 0 1rem;
			}

			/* Cards */
			.cards {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
			}
			.card {
				display: block;
				padding: 1.25rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				text-decoration: none;
				color: inherit;
				transition: box-shadow 0.2s ease, border-color 0.2s ease;
			}
			.card:hover {
				box-shadow: var(--box-shadow);
				border-color: rgb(var(--gray));
			}
			.card-icon {
				font-size: 1.6em;
				margin-bottom: 0.5rem;
				display: block;
			}
			.card h2 {
				font-size: 1em;
				margin-bottom: 0.25rem;
				color: rgb(var(--black));
			}
			.card p {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin: 0;
				line-height: 1.5;
			}

			/* Recent posts */
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				padding: 0.65rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				font-size: 0.9em;
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-list a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.post-list a:hover {
				color: rgb(var(--accent));
			}
			.post-list .post-date {
				font-size: 0.8em;
				color: rgb(var(--gray));
				white-space: nowrap;
				flex-shrink: 0;
			}

			@media (max-width: 600px) {
				.hero {
					flex-direction: column;
					text-align: center;
					gap: 1.25rem;
				}
				.cards {
					grid-template-columns: 1fr;
				}
				.post-list li {
					flex-direction: column;
					gap: 0.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<img class="hero-photo" src="/brian-hanley.png" alt="Brian Hanley" />
				<div class="hero-text">
					<h1>Brian Hanley</h1>
					<p class="tagline">Data Science &amp; Anthropology · Indiana University</p>
					<p>
						This site is a living record of my academic and professional work, both inside and outside IU.
						It covers applied research, higher education operations, data pipelines, and the occasional
						project that does not fit neatly into any of those categories.
					</p>
					<p>
						My background combines data science, anthropology, and computer science. Most of my work sits
						at the intersection of quantitative methods and human systems: how people move through
						institutions, how markets behave under pressure, how training programs succeed or fail.
					</p>
				</div>
			</div>

			<hr />

			<p class="section-label">Explore</p>
			<div class="cards">
				<a class="card" href="/blog">
					<span class="card-icon">✍️</span>
					<h2>Blog</h2>
					<p>Research writeups, operational analysis, and applied projects.</p>
				</a>
				<a class="card" href="/presentations">
					<span class="card-icon">📊</span>
					<h2>Presentations</h2>
					<p>Slides and talks from academic and professional work.</p>
				</a>
				<a class="card" href="/cv">
					<span class="card-icon">📄</span>
					<h2>CV</h2>
					<p>Education, experience, and skills.</p>
				</a>
			</div>

			<p class="section-label">Recent Posts</p>
			<ul class="post-list">
				<li>
					<a href="/blog/wow-economics-ban-wave">World of Warcraft as an Economic Laboratory: What a Ban Wave Taught Us About Supply and Demand</a>
					<span class="post-date">Mar 17, 2026</span>
				</li>
				<li>
					<a href="/blog/rethinking-parttime-training">Rethinking Part-Time Staff Training: From Weeks to Hours</a>
					<span class="post-date">Nov 18, 2025</span>
				</li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
