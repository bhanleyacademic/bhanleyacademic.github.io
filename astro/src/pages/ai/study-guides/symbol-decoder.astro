---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<html lang="en">
  <head>
    <BaseHead title="Math Symbol Decoder" description="An interactive reference for decoding common math symbols used in computer science and AI." />
    <style>
      body, html { margin: 0; padding: 0; height: 100%; }
      .page-wrap {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      .iframe-container {
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      iframe {
        flex: 1;
        width: 100%;
        border: none;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <div class="page-wrap">
      <Header />
      <div class="iframe-container">
        <iframe src="/study-guides/symbol-decoder.html" title="Math Symbol Decoder"></iframe>
      </div>
      <Footer />
    </div>
  </body>
</html>
