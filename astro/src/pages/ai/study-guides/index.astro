---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const guides = [
  {
    title: "Big O Notation",
    description: "An interactive visual guide to Big O notation and algorithm complexity.",
    href: "/ai/study-guides/big-o",
  },
  {
    title: "Math Symbol Decoder",
    description: "An interactive reference for decoding common math symbols used in computer science and AI.",
    href: "/ai/study-guides/symbol-decoder",
  },
  {
    title: "D321 — Start From Zero Study Guide",
    description: "A comprehensive start-from-zero study guide for D321.",
    href: "/ai/study-guides/d321-full-guide",
  },
  {
    title: "D321 Exam Study Guide",
    description: "A focused exam study guide for D321.",
    href: "/ai/study-guides/d321-study-guide",
  },
];
---

<html lang="en">
  <head>
    <BaseHead title="Study Guides" description="Interactive study guides for computer science and AI topics." />
    <style>
      main {
        max-width: 720px;
        margin: 2rem auto;
        padding: 0 1rem;
      }
      h1 {
        margin-bottom: 1.5rem;
      }
      ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      li a {
        display: block;
        padding: 1rem 1.25rem;
        border: 1px solid rgb(var(--gray-light));
        border-radius: 8px;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.2s ease;
      }
      li a:hover {
        box-shadow: var(--box-shadow);
      }
      li a h2 {
        margin: 0 0 0.25rem;
        font-size: 1.25rem;
        color: rgb(var(--accent));
      }
      li a p {
        margin: 0;
        color: rgb(var(--gray));
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Study Guides</h1>
      <ul>
        {guides.map((g) => (
          <li>
            <a href={g.href}>
              <h2>{g.title}</h2>
              <p>{g.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
