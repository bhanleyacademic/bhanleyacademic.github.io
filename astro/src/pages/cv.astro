---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`CV | ${SITE_TITLE}`} description="Curriculum vitae for Brian Hanley — Data Science & Anthropology, Indiana University." />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em 4em;
			}

			h1 {
				font-size: 2em;
				margin-bottom: 0.1em;
			}
			.subtitle {
				font-size: 0.95em;
				color: rgb(var(--gray));
				margin-bottom: 0.3em;
			}
			.contact-line {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 2rem;
			}
			.contact-line a {
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.contact-line a:hover {
				color: rgb(var(--accent));
			}

			/* Section */
			.cv-section {
				margin-top: 2.25rem;
			}
			.cv-section h2 {
				font-size: 0.75em;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-weight: 700;
				color: rgb(var(--gray));
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.4rem;
				margin-bottom: 1.25rem;
			}

			/* Entry */
			.cv-entry {
				display: grid;
				grid-template-columns: 1fr auto;
				gap: 0 1.5rem;
				margin-bottom: 1.4rem;
			}
			.cv-entry-title {
				font-weight: 600;
				font-size: 0.95em;
				color: rgb(var(--black));
				margin-bottom: 0.1em;
			}
			.cv-entry-sub {
				font-size: 0.875em;
				color: rgb(var(--gray-dark));
				margin-bottom: 0.25em;
			}
			.cv-entry-desc {
				font-size: 0.85em;
				color: rgb(var(--gray));
				line-height: 1.6;
				margin: 0;
				grid-column: 1 / -1;
			}
			.cv-entry-meta {
				font-size: 0.8em;
				color: rgb(var(--gray));
				text-align: right;
				white-space: nowrap;
				padding-top: 0.15em;
			}

			/* Skills list */
			.skill-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 0.5rem 2rem;
				font-size: 0.875em;
				color: rgb(var(--gray-dark));
			}
			.skill-category {
				font-weight: 600;
				color: rgb(var(--black));
			}

			/* Publications */
			.pub-item {
				font-size: 0.875em;
				line-height: 1.65;
				margin-bottom: 0.9rem;
				color: rgb(var(--gray-dark));
			}
			.pub-item a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.pub-item a:hover {
				color: rgb(var(--accent));
			}
			.pub-item .pub-meta {
				color: rgb(var(--gray));
				font-size: 0.9em;
			}

			@media (max-width: 520px) {
				.cv-entry {
					grid-template-columns: 1fr;
				}
				.cv-entry-meta {
					text-align: left;
					padding-top: 0;
				}
				.skill-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Brian Hanley</h1>
			<p class="subtitle">Data Science &amp; Anthropology &mdash; Indiana University Bloomington</p>
			<p class="contact-line">
				Bloomington, IN &nbsp;&bull;&nbsp;
				<a href="https://bsky.app/profile/food-and-data.bsky.social" target="_blank">Bluesky</a> &nbsp;&bull;&nbsp;
				<a href="https://bhanleyacademic.github.io">bhanleyacademic.github.io</a>
			</p>

			<!-- Education -->
			<section class="cv-section">
				<h2>Education</h2>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Indiana University Bloomington</p>
						<p class="cv-entry-sub">B.S. Data Science (in progress)</p>
					</div>
					<p class="cv-entry-meta">Aug 2023 &ndash; Present<br/>Bloomington, IN</p>
					<p class="cv-entry-desc">
						Coursework in data visualization (INFO-I422), creativity and technology (INFO-I400),
						econometrics, and applied anthropological methods.
					</p>
				</div>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Citrus College</p>
						<p class="cv-entry-sub">A.S. Computer Science &nbsp;&bull;&nbsp; A.S. Psychology &nbsp;&bull;&nbsp; A.A. Anthropology</p>
					</div>
					<p class="cv-entry-meta">Aug 2020 &ndash; Jun 2023<br/>Azusa, CA</p>
					<p class="cv-entry-desc">
						Three associate degrees completed concurrently. Developed the cross-disciplinary foundation
						in computational methods, behavioral science, and cultural analysis that informs current work.
					</p>
				</div>
			</section>

			<!-- Experience -->
			<section class="cv-section">
				<h2>Experience</h2>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Indiana University &ndash; Student Records Representative</p>
						<p class="cv-entry-sub">Higher Education Operations</p>
					</div>
					<p class="cv-entry-meta">2025 &ndash; Present<br/>Bloomington, IN</p>
					<p class="cv-entry-desc">
						Applied research in service desk operations, including training program redesign (checkpoint-based
						hours model), structured shadowing frameworks, and LMS curriculum sequencing for part-time
						student employees.
					</p>
				</div>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Citrus College</p>
						<p class="cv-entry-sub">Professional Expert &ndash; Tutor (English, Speech, Anthropology)</p>
					</div>
					<p class="cv-entry-meta">Feb 2022 &ndash; Jan 2024<br/>Azusa, CA</p>
					<p class="cv-entry-desc">
						Provided individual and small-group tutoring across English composition, speech communication,
						and anthropology. Continued remotely into the first semester at IU.
					</p>
				</div>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">American Bath Factory</p>
						<p class="cv-entry-sub">IT Manager</p>
					</div>
					<p class="cv-entry-meta">Feb 2011 &ndash; Jan 2017<br/>Corona, CA</p>
					<p class="cv-entry-desc">
						Managed all technology infrastructure for a manufacturing operation: networking,
						workstations, enterprise software, and vendor relationships.
					</p>
				</div>
			</section>

			<!-- Research & Projects -->
			<section class="cv-section">
				<h2>Research &amp; Projects</h2>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">WoW Auction House Economics</p>
						<p class="cv-entry-sub">Applied Econometrics &ndash; Independent Research</p>
					</div>
					<p class="cv-entry-meta">Mar 2026</p>
					<p class="cv-entry-desc">
						Collected 3.1 million rows of hourly Auction House data (309 snapshots, 10,145 items)
						via the Blizzard Battle.net API. Designed and ran five econometric models against a
						real, undocumented supply shock (mass ban wave, March 17 2026): arc price elasticity
						of demand, supply shock equilibrium, event study (CAR), difference-in-differences,
						and a Laspeyres virtual CPI. Results show a 325% DiD price effect and 7.1% aggregate
						inflation within 48 hours. Full working paper and plain-English companion guide
						available on request. Stack: Python, SQLite, pandas, NumPy, SciPy, matplotlib, LaTeX.
					</p>
				</div>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Live TV Emulator</p>
						<p class="cv-entry-sub">Personal Project &ndash; Systems &amp; Cultural Engineering</p>
					</div>
					<p class="cv-entry-meta">Ongoing</p>
					<p class="cv-entry-desc">
						Software that emulates a live television viewing experience. Combines systems-level
						scheduling and playback engineering with a cultural thesis about media nostalgia,
						identity, and how audiences relate to linear broadcast formats.
					</p>
				</div>

				<div class="cv-entry">
					<div>
						<p class="cv-entry-title">Azeroth Data &ndash; WoW Visualization</p>
						<p class="cv-entry-sub">INFO-I422 Data Visualization</p>
					</div>
					<p class="cv-entry-meta">2024</p>
					<p class="cv-entry-desc">
						Interactive data visualization project exploring World of Warcraft game data.
						Presented as part of IU's data visualization coursework.
					</p>
				</div>
			</section>

			<!-- Presentations -->
			<section class="cv-section">
				<h2>Presentations</h2>

				<div class="pub-item">
					<a href="https://docs.google.com/presentation/d/1Xk--4Tch4rgrAE46k9XhEXeAe0wUUZKnTtqfU7YPKIo/edit?usp=sharing" target="_blank">Azeroth Data</a><br/>
					<span class="pub-meta">INFO-I422 Data Visualization &bull; Indiana University</span>
				</div>
				<div class="pub-item">
					<a href="https://docs.google.com/presentation/d/1FxGmZJahpn3XRRF0acd3RuvW72GkizlraeTkFnYmtWc/edit?usp=sharing" target="_blank">Consumer-Driven Innovation</a><br/>
					<span class="pub-meta">INFO-I400 Creativity, Innovation &amp; Tech &bull; Indiana University</span>
				</div>
				<div class="pub-item">
					<a href="https://docs.google.com/presentation/d/1zOvXUreW2UYo2rc7NO4jrsa_WiSOwnKZHoW5AXAGaPc/edit?usp=sharing" target="_blank">Imitators in Streaming Services</a><br/>
					<span class="pub-meta">INFO-I400 Creativity, Innovation &amp; Tech &bull; Indiana University</span>
				</div>
				<div class="pub-item">
					<a href="https://docs.google.com/presentation/d/1WjG7Uu1qqN8in_QAQAFYQSH8yGOr_zhnHcHnQKvsJos/edit?usp=sharing" target="_blank">The Cost of Creativity</a><br/>
					<span class="pub-meta">INFO-I400 Creativity, Innovation &amp; Tech &bull; Indiana University</span>
				</div>
			</section>

			<!-- Writing -->
			<section class="cv-section">
				<h2>Writing</h2>

				<div class="pub-item">
					<a href="/blog/wow-economics-ban-wave">World of Warcraft as an Economic Laboratory: What a Ban Wave Taught Us About Supply and Demand</a><br/>
					<span class="pub-meta">bhanleyacademic.github.io &bull; March 2026 &bull; Applied econometrics, virtual economy research</span>
				</div>
				<div class="pub-item">
					<a href="/blog/rethinking-parttime-training">Rethinking Part-Time Staff Training: From Weeks to Hours</a><br/>
					<span class="pub-meta">bhanleyacademic.github.io &bull; November 2025 &bull; Higher education operations, training design</span>
				</div>
			</section>

			<!-- Skills -->
			<section class="cv-section">
				<h2>Skills</h2>
				<div class="skill-grid">
					<div>
						<span class="skill-category">Languages</span><br/>
						Python, JavaScript, PHP, C#, C++, HTML5/CSS
					</div>
					<div>
						<span class="skill-category">Data &amp; Analysis</span><br/>
						pandas, NumPy, SciPy, matplotlib, SQLite, Plotly, Tableau, PowerBI
					</div>
					<div>
						<span class="skill-category">Methods</span><br/>
						Econometrics, machine learning, data visualization, API integration
					</div>
					<div>
						<span class="skill-category">Other</span><br/>
						LaTeX, Docker, Git, Linux, LMS administration &amp; design (Canvas)
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
